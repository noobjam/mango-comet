# Copy to .env on the GPU VM, or export these variables before starting.

# Incident V3: point only at the completed map-ready viewer emitted by
# run_incident_v3.py. Legacy raw/optimized V1 bundles are also supported, but
# the intermediate incidents_v3_* analytics release is not a viewer bundle.
STORY_MAP_RUN_DIR=/mnt/KSA-Oasis/fields_health_v2/clusters/runs/weekly_monitor_v1/releases/incident_viewer_v3_JOB_TAG

# Static viewer directory. Usually leave this alone.
STORY_MAP_STATIC_DIR=./static

# Server bind. Keep loopback for SSH-tunnel testing. Bind to 0.0.0.0 only behind
# explicit firewall/reverse-proxy access control; this prototype has no auth.
STORY_MAP_HOST=127.0.0.1
STORY_MAP_PORT=8877
STORY_MAP_LOG_LEVEL=INFO

# Satellite basemap. Default is Esri World Imagery. Replace with MapTiler,
# Mapbox, self-hosted raster tiles, or a TiTiler TileJSON/raster endpoint.
STORY_MAP_RASTER_TILES=https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}
STORY_MAP_RASTER_ATTRIBUTION=Tiles (C) Esri, Maxar, Earthstar Geographics, and the GIS User Community

# Bound per-frame GeoJSON. Raise only after measuring response size and browser
# rendering; full production should still move to PMTiles/MVT.
STORY_MAP_DEFAULT_FEATURE_LIMIT=5000
STORY_MAP_MAX_FEATURE_LIMIT=20000

# Small in-process response/static cache. A front proxy is still recommended for
# shared caching across workers and for production TLS/compression policy.
STORY_MAP_CACHE_SECONDS=300
STORY_MAP_CACHE_ENTRIES=256
# Combined raw+gzip bytes retained by one process across API and static caches
# (15/16 API, 1/16 static). Oversized payloads bypass caching; lower this after
# measuring VM RSS if 512 MiB is too generous.
STORY_MAP_CACHE_MAX_BYTES=536870912

# Bound concurrent DuckDB/GeoJSON work from rapid scrubbing or abandoned browser
# requests. Excess uncached requests receive 503 + Retry-After instead of
# queueing indefinitely. Tune against VM CPU cores and measured p95 latency.
STORY_MAP_QUERY_CONCURRENCY=8

# Gzip JSON/static responses at or above this many bytes when the client accepts
# gzip. Set to 0 only if compression is handled entirely by a trusted front proxy.
STORY_MAP_GZIP_MIN_BYTES=1024
